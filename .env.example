# Clerk (in produzione usa pk_live_ / sk_live_ e il dominio configurato nel dashboard Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Obbligatorio in produzione: URL pubblico dell’app (es. https://app.example.com) per authorizedParties e redirect
# NEXT_PUBLIC_APP_URL=https://app.example.com

# Slug stabile per questa app (attribuzione marketing / Stripe metadata tra più prodotti con stesso Clerk). Esempi: bandi-ai, labeltools-press-review, qr-generator-pro
# NEXT_PUBLIC_APP_SLUG=bandi-ai

# Origini extra per Clerk (middleware authorizedParties), separate da virgola — es. preview URL o secondo dominio
# NEXT_PUBLIC_CLERK_ALLOWED_ORIGINS=https://xxx.vercel.app

# Logo MediaMatter: link Google Drive “Chiunque abbia il link” vanno bene; vengono normalizzati in uc?export=view
# NEXT_PUBLIC_MEDIAMATTER_LOGO_URL_BLACK=
# NEXT_PUBLIC_MEDIAMATTER_LOGO_URL_WHITE=
# Legacy (singolo URL):
# NEXT_PUBLIC_MEDIAMATTER_LOGO_URL=

# Scraping URL (opzionale)
# URL_FETCH_TIMEOUT_MS=45000
# URL_SCRAPE_MAX_DEPTH=2
# URL_SCRAPE_MAX_PAGES=14
# URL_SCRAPE_MAX_PDFS=18

# Database (Vercel Postgres or any Postgres)
POSTGRES_URL=postgres://user:password@host:5432/database?sslmode=require

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Price IDs (NEXT_PUBLIC_* servono per i pulsanti Sottoscrivi nella pagina Abbonamento)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_UNLIMITED_PRICE_ID=price_...

# LLM (use one or both)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Utenti di test senza limiti (opzionale, ID Clerk separati da virgola)
# TEST_USERS_WHITELIST=user_2abc...,user_2def...
